# Leave empty to route /admin/* through the Vite dev-server proxy (recommended for local dev)
# Set to a full URL only when targeting a non-proxied API (e.g. a staging server)
VITE_API_BASE_URL=
VITE_KEYCLOAK_URL=http://localhost:9090
VITE_KEYCLOAK_REALM=pisp
VITE_KEYCLOAK_CLIENT_ID=fee-engine-admin-ui
